---
import { buildSEOMeta } from '../../utils/seo';
import type { SEOProps } from '../../utils/seo';
import siteData from '../../data/site.json';

interface Props extends SEOProps {}

const props = Astro.props;
const siteURL = Astro.site?.toString().replace(/\/$/, '') || 'https://astro.treyturner.info';
const pageCanonical = props.canonicalURL || `${siteURL}${Astro.url.pathname}`;

const meta = buildSEOMeta({ ...props, canonicalURL: pageCanonical }, {
  siteName: siteData.name,
  defaultDescription: siteData.tagline,
  siteURL,
});
---

<title>{meta.title}</title>
<meta name="description" content={meta.description} />
<link rel="canonical" href={meta.canonicalURL} />
<meta property="og:title" content={meta.ogTitle} />
<meta property="og:description" content={meta.ogDescription} />
<meta property="og:type" content={meta.ogType} />
<meta property="og:url" content={meta.canonicalURL} />
<meta property="og:site_name" content={meta.ogSiteName} />
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={meta.ogTitle} />
<meta name="twitter:description" content={meta.ogDescription} />
