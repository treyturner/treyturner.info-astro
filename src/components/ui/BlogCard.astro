---
import { formatBlogDate } from '../../schemas/blog';

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      date: Date;
      description: string;
      draft?: boolean;
      tags: string[];
    };
  };
}

const { post } = Astro.props;
---

<article class="blog-card">
  <a href={`/blog/${post.id}`} class="blog-card-link">
    <h2 class="blog-card-title">{post.data.title}</h2>
  </a>
  <div class="blog-card-meta">
    <time class="blog-card-date" datetime={new Date(post.data.date).toISOString()}>
      {formatBlogDate(post.data.date)}
    </time>
    {post.data.draft && <span class="blog-card-draft">Draft</span>}
  </div>
  <p class="blog-card-description">{post.data.description}</p>
  {post.data.tags.length > 0 && (
    <ul class="blog-card-tags">
      {post.data.tags.map((tag) => (
        <li class="blog-card-tag">{tag}</li>
      ))}
    </ul>
  )}
</article>

<style>
  .blog-card {
    padding: var(--spacing-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .blog-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-sm);
  }

  .blog-card-link {
    text-decoration: none;
    color: inherit;
  }

  .blog-card-link:hover {
    text-decoration: none;
  }

  .blog-card-title {
    font-size: 1.375rem;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .blog-card-link:hover .blog-card-title {
    color: var(--color-primary);
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-sm);
  }

  .blog-card-date {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }

  .blog-card-draft {
    font-size: 0.75rem;
    padding: var(--spacing-xs) var(--spacing-sm);
    background-color: var(--color-accent);
    color: white;
    border-radius: var(--radius-full);
    font-weight: 600;
  }

  .blog-card-description {
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .blog-card-tags {
    display: flex;
    gap: var(--spacing-sm);
    list-style: none;
    flex-wrap: wrap;
    margin-top: var(--spacing-sm);
  }

  .blog-card-tag {
    font-size: 0.8125rem;
    padding: var(--spacing-xs) var(--spacing-sm);
    background-color: var(--color-bg-secondary);
    border-radius: var(--radius-full);
    color: var(--color-text-secondary);
  }
</style>
