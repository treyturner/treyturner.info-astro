---
import { Image } from 'astro:assets';
import type { Recommendation } from '../../schemas/recommendations';
import { formatRecommendationDate } from '../../schemas/recommendations';

interface Props {
  recommendation: Recommendation;
}

const { recommendation } = Astro.props;

const allPeople = import.meta.glob<{ default: ImageMetadata }>('../../assets/people/*.jpg', { eager: true });
const allLogos  = import.meta.glob<{ default: ImageMetadata }>('../../assets/logos/*',      { eager: true });

const photoKey = `../../assets/people/${recommendation.author.toLowerCase().replace(/\s+/g, '-')}.jpg`;
const photoSrc = allPeople[photoKey]?.default;
---

<article class="recommendation-card">
  <blockquote class="recommendation-text">
    <p>{recommendation.text}</p>
  </blockquote>
  <footer class="recommendation-footer">
    <div class="recommendation-author-block">
      {photoSrc && (
        <Image class="recommendation-photo" src={photoSrc} alt="" height={44} width={44} />
      )}
      <div class="recommendation-author">
        <a href={recommendation.linkedIn} class="recommendation-author-link"
           target="_blank" rel="noopener noreferrer">
          <strong>{recommendation.author}</strong>
        </a>
        <time class="recommendation-date">{formatRecommendationDate(recommendation.date)}</time>
      </div>
    </div>
    <div class="recommendation-roles">
      {recommendation.roles.map((r) => {
        const logoKey = `../../assets/logos/${r.logo}`;
        const roleLogo = allLogos[logoKey]?.default;
        return (
          <div class="recommendation-role-entry">
            <div class="recommendation-role-text">
              <span class="recommendation-role">{r.role} at {r.company}</span>
              <span class="recommendation-relationship">{r.relationship}</span>
            </div>
            {roleLogo && (
              <Image class="recommendation-role-logo" src={roleLogo} alt={r.company} height={40} />
            )}
          </div>
        );
      })}
    </div>
  </footer>
</article>

<style>
  .recommendation-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--spacing-xl);
    background-color: var(--color-surface);
  }

  .recommendation-card + .recommendation-card {
    margin-top: var(--spacing-xl);
  }

  .recommendation-text {
    margin: 0 0 var(--spacing-lg) 0;
    padding: 0;
    border: none;
  }

  .recommendation-text p {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text);
    font-style: italic;
    margin-bottom: 0;
  }

  .recommendation-text p::before {
    content: '\201C';
    font-size: 1.5em;
    color: var(--color-primary);
    font-weight: 700;
    margin-right: 0.1em;
  }

  .recommendation-text p::after {
    content: '\201D';
    font-size: 1.5em;
    color: var(--color-primary);
    font-weight: 700;
    margin-left: 0.1em;
  }

  .recommendation-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--color-border);
  }

  /* Left: photo + author info */
  .recommendation-author-block {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .recommendation-photo {
    height: 2.75rem;
    width: 2.75rem;
    border-radius: var(--radius-full);
    object-fit: cover;
    flex-shrink: 0;
  }

  .recommendation-author {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .recommendation-author-link {
    color: inherit;
    text-decoration: none;
  }

  .recommendation-author-link:hover {
    text-decoration: underline;
  }

  .recommendation-author-link strong {
    font-size: 1rem;
    color: var(--color-text);
  }

  .recommendation-date {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  /* Right: role entries laid out horizontally */
  .recommendation-roles {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: var(--spacing-md);
    align-items: flex-start;
    justify-content: flex-end;
  }

  /* Each entry: two-line text column + logo to the right spanning both lines */
  .recommendation-role-entry {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .recommendation-role-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--spacing-xs);
  }

  .recommendation-role {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .recommendation-relationship {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    background-color: var(--color-bg-secondary);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-full);
    align-self: flex-end;
  }

  .recommendation-role-logo {
    height: 2.5rem;
    width: auto;
    max-width: 5rem;
    object-fit: contain;
    flex-shrink: 0;
  }
</style>
